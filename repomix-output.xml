from pathlib import Path

import pytest

REQUIRED_FILES = [
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "Makefile",
    "pyproject.toml",
]

REQUIRED_DIRECTORIES = [
    ".github/ISSUE_TEMPLATE",
